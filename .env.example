# Auteur Docker Compose 配置
#
# 使用：cp .env.example .env，按需修改后 docker compose up -d
# 所有 LLM / TTS / TOS / Jamendo 密钥不在这里——启动后进前端「系统设置」UI 填写（落 app_config 表）。

# ─── MySQL ────────────────────────────────────────────────
# 容器内 root 密码 + 数据库名。生产部署务必改一个不容易猜的密码。
MYSQL_PASSWORD=auteur
MYSQL_DATABASE=auteur

# ─── 端口映射 ─────────────────────────────────────────────
# 前端访问端口（浏览器打开 http://localhost:${FRONTEND_PORT}）
FRONTEND_PORT=5174
# 后端 REST API 端口（前端通过 nginx 反代到容器内 backend:8082，所以宿主机不一定要暴露；
# 留出来方便 curl 调试 / 浏览器扩展回写）
BACKEND_PORT=8082

# ─── JVM ──────────────────────────────────────────────────
# 后端 JVM 堆大小。低配机器降到 -Xms256m -Xmx1g
JAVA_OPTS=-Xms512m -Xmx2g

# ─── Remotion（可选）─────────────────────────────────────
# Docker 容器里默认关闭 Remotion，走纯 ffmpeg 路径。
# 想用 Remotion 可视化合成？在宿主机另跑 `cd renderer && npm install && npm run dev`，
# 这里设 true 并通过 extra_hosts / 网络配置让 backend 能访问到。
AUTEUR_REMOTION_ENABLED=false
